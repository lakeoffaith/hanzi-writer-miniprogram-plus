.custom-button {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  box-sizing: border-box;
  transition: all 0.2s ease;
  border: 2rpx solid transparent;
}

/* 尺寸 */
.small {
  height: 56rpx;
  padding: 0 24rpx;
  font-size: 24rpx;
}

.medium {
  height: 80rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
}

.large {
  height: 96rpx;
  padding: 0 48rpx;
  font-size: 32rpx;
}

/* 类型 */
.default {
  background-color: #f5f5f5;
  color: #333;
  border-color: #ddd;
}

.default.pressed {
  background-color: #e5e5e5;
}

.primary {
  background-color: #07c160;
  color: #fff;
  border-color: #07c160;
}

.primary.pressed {
  background-color: #06ad56;
}

.warning {
  background-color: #fa5151;
  color: #fff;
  border-color: #fa5151;
}

.warning.pressed {
  background-color: #e64545;
}

/* 禁用状态 */
.disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

.button-text {
  line-height: 1.2;
}
